# ─────────────────────────────────────────────────────────────────────────────
# Nexus — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# Local dev URL — change to your Vercel URL for production
NEXTAUTH_URL=http://localhost:3000

# ── Identity Provider 1: Okta ─────────────────────────────────────────────────
# Okta Admin Console → Applications → Your App → General tab
OKTA_CLIENT_ID=0oaXXXXXXXXXXXXXXXXX
OKTA_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Format: https://<your-okta-domain>.okta.com/oauth2/default
OKTA_ISSUER=https://dev-12345678.okta.com/oauth2/default

# Callback URL to register in Okta:
#   http://localhost:3000/api/auth/callback/okta          (dev)
#   https://your-app.vercel.app/api/auth/callback/okta   (prod)

# ── Identity Provider 2: Microsoft Entra ID (Azure AD) ───────────────────────
# Azure Portal → Entra ID → App registrations → Your App → Overview
ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_CLIENT_SECRET=your_entra_client_secret_here
# Your Azure AD tenant ID (found in Entra ID → Overview)
ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Callback URL to register in Azure:
#   http://localhost:3000/api/auth/callback/azure-ad          (dev)
#   https://your-app.vercel.app/api/auth/callback/azure-ad   (prod)
