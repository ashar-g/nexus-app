# Okta OIDC Configuration
# Get these from your Okta Developer Console → Applications → Your App

OKTA_CLIENT_ID=your_okta_client_id_here
OKTA_CLIENT_SECRET=your_okta_client_secret_here
OKTA_ISSUER=https://your-okta-domain.okta.com/oauth2/default

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_run_openssl_rand_base64_32

# For production on Vercel, set NEXTAUTH_URL to your deployed domain
# e.g. https://nexus-app.vercel.app
