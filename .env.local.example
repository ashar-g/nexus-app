# ─────────────────────────────────────────────────────────────────────────────
# Nexus — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# Local dev URL — change to your production URL for deployment
NEXTAUTH_URL=http://localhost:3000

# ── Identity Provider 1: Okta ─────────────────────────────────────────────────
# Okta Admin Console → Applications → Your App → General tab
OKTA_CLIENT_ID=0oaXXXXXXXXXXXXXXXXX
OKTA_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Format: https://<your-okta-domain>.okta.com/oauth2/default
OKTA_ISSUER=https://dev-12345678.okta.com/oauth2/default

# Callback URL to register in Okta:
#   http://localhost:3000/api/auth/callback/okta          (dev)
#   https://your-app.vercel.app/api/auth/callback/okta   (prod)

# ── Identity Provider 2: Microsoft Entra External ID (CIAM) ──────────────────
# Azure Portal → entra.microsoft.com → Switch to your EXTERNAL tenant
# Then: App registrations → Your App → Overview

# Application (client) ID
ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client secret value (not the secret ID)
ENTRA_CLIENT_SECRET=your_entra_client_secret_here

# Directory (tenant) ID of your External ID tenant
ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# The subdomain of your CIAM tenant
# e.g. if your tenant domain is "mytenant.ciamlogin.com", set this to "mytenant"
ENTRA_TENANT_SUBDOMAIN=mytenant

# !! IMPORTANT — Callback URLs to register in your Azure App Registration:
#   http://localhost:3000/api/auth/callback/microsoft-entra-external   (dev)
#   https://your-app.vercel.app/api/auth/callback/microsoft-entra-external (prod)
#
# Note: The callback path uses "microsoft-entra-external" (NOT "azure-ad").
# In Azure Portal → App Registration → Authentication → Add a platform → Web
